rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts: public read/write (app-layer password guards admin actions)
    match /posts/{id} {
      allow read, write: if true;
    }

    // Courses: public read/write
    match /courses/{id} {
      allow read, write: if true;
    }

    // Submissions: public read/write
    match /submissions/{id} {
      allow read, write: if true;
    }

    // Settings: public read/write
    match /settings/{id} {
      allow read, write: if true;
    }

    // Locations: public read/write
    match /locations/{id} {
      allow read, write: if true;
    }

    // Trips: public read/write
    match /trips/{id} {
      allow read, write: if true;
    }
  }
}
